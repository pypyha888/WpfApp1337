<Page x:Class="WpfApp1337.Pages.PageAdmin"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F7F8FA">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="White">
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28" Background="#E63946"
                            CornerRadius="4" Margin="0,0,10,0">
                        <TextBlock Text="T" FontFamily="Segoe UI Black"
                                   FontSize="16" Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Административная панель"
                               FontFamily="Segoe UI Semibold" FontSize="18"
                               Foreground="#1A1A2E" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Content="← Назад" Style="{StaticResource BtnOutline}"
                        HorizontalAlignment="Right" Click="OnBackClick"/>
            </Grid>
        </Border>
        <Rectangle Grid.Row="1" Fill="#E5E7EB"/>

        <!-- Вкладки -->
        <TabControl Grid.Row="2" Margin="20,16,20,16"
                    Background="White">

            <!-- Пользователи и роли -->
            <TabItem Header="Пользователи и роли">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="UsersGrid"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserResizeColumns="True" RowHeight="44"
                              SelectionChanged="OnUserSelected">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding Id}" Width="55"/>
                            <DataGridTextColumn Header="Имя"
                                                Binding="{Binding UserName}" Width="*"/>
                            <DataGridTextColumn Header="Логин"
                                                Binding="{Binding Login}" Width="130"/>
                            <DataGridTextColumn Header="Телефон"
                                                Binding="{Binding Phone}" Width="150"/>
                            <DataGridTextColumn Header="Email"
                                                Binding="{Binding Email}" Width="180"/>
                            <DataGridTemplateColumn Header="Роль" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="8,3"
                                                HorizontalAlignment="Left" Margin="8,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#EFF6FF"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RoleId}" Value="1">
                                                            <Setter Property="Background" Value="#FFF0F0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding RoleId}" Value="2">
                                                            <Setter Property="Background" Value="#FFF7ED"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontFamily="Segoe UI"
                                                       FontSize="12" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Покупатель"/>
                                                        <Setter Property="Foreground" Value="#2563EB"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RoleId}" Value="1">
                                                                <Setter Property="Text" Value="Администратор"/>
                                                                <Setter Property="Foreground" Value="#E63946"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding RoleId}" Value="2">
                                                                <Setter Property="Text" Value="Менеджер"/>
                                                                <Setter Property="Foreground" Value="#D97706"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Панель смены роли -->
                    <Border Grid.Row="1" Background="#F9FAFB"
                            CornerRadius="8" Margin="0,12,0,0"
                            Padding="16,12" BorderBrush="#E5E7EB" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Выбран:"
                                       FontFamily="Segoe UI" FontSize="13"
                                       Foreground="#6B7280"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock x:Name="SelectedUserBlock" Grid.Column="1"
                                       FontFamily="Segoe UI Semibold" FontSize="13"
                                       Foreground="#1A1A2E" VerticalAlignment="Center"/>
                            <TextBlock Text="Роль:" Grid.Column="2"
                                       FontFamily="Segoe UI" FontSize="13"
                                       Foreground="#6B7280"
                                       VerticalAlignment="Center" Margin="20,0,10,0"/>
                            <ComboBox x:Name="RoleComboBox" Grid.Column="3"
                                      Style="{StaticResource ComboField}">
                                <ComboBoxItem Content="1 — Администратор" Tag="1"/>
                                <ComboBoxItem Content="2 — Менеджер"      Tag="2"/>
                                <ComboBoxItem Content="3 — Покупатель"    Tag="3"/>
                            </ComboBox>
                            <Button Grid.Column="4" Content="Сохранить"
                                    Style="{StaticResource BtnSuccess}"
                                    Margin="10,0,0,0"
                                    Click="OnSaveRoleClick"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Все заказы -->
            <TabItem Header="Все заказы">
                <DataGrid x:Name="AllOrdersGrid" Margin="16"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserResizeColumns="True" RowHeight="44">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="Логин"
                                            Binding="{Binding UserLogin}" Width="120"/>
                        <DataGridTextColumn Header="Товар"
                                            Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Кол-во"
                                            Binding="{Binding Quantity}" Width="80"/>
                        <DataGridTextColumn Header="Цена, ₽"
                                            Binding="{Binding UnitPrice, StringFormat=\{0:N0\}}"
                                            Width="110"/>
                        <DataGridTextColumn Header="Дата"
                                            Binding="{Binding OrderDate, StringFormat=\{0:dd.MM.yyyy\}}"
                                            Width="110"/>
                        <DataGridTextColumn Header="Статус"
                                            Binding="{Binding Status}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Поставщики -->
            <TabItem Header="Поставщики">
                <DataGrid x:Name="SuppliersGrid" Margin="16"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserResizeColumns="True" RowHeight="44">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="Поставщик"
                                            Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Контакт"
                                            Binding="{Binding ContactName}" Width="150"/>
                        <DataGridTextColumn Header="Телефон"
                                            Binding="{Binding ContactPhone}" Width="150"/>
                        <DataGridTextColumn Header="Email"
                                            Binding="{Binding Email}" Width="180"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
