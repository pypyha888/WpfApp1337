<Page x:Class="WpfApp1337.Pages.PageAdmin"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Административная панель" Background="#F4F6F8" Height="499" Width="895">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="#1A237E" BorderThickness="0">
            <Grid Margin="16,0">
                <TextBlock Text="⚙ Административная панель" VerticalAlignment="Center"
                           FontSize="17" FontWeight="Bold" Foreground="White"/>
                <Button Content="← Назад" Width="90" Height="32"
                        HorizontalAlignment="Right" Click="OnBackClick"
                        Background="White" Foreground="#1A237E"/>
            </Grid>
        </Border>

        <!-- Вкладки -->
        <TabControl Grid.Row="1" Margin="16,10,16,10">

            <!-- Пользователи и роли -->
            <TabItem Header="👥 Пользователи и роли">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="UsersGrid"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserResizeColumns="True"
                              SelectionChanged="OnUserSelected">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"       Binding="{Binding Id}"       Width="55"/>
                            <DataGridTextColumn Header="Имя"      Binding="{Binding UserName}"  Width="*"/>
                            <DataGridTextColumn Header="Логин"    Binding="{Binding Login}"     Width="120"/>
                            <DataGridTextColumn Header="Телефон"  Binding="{Binding Phone}"     Width="140"/>
                            <DataGridTextColumn Header="Email"    Binding="{Binding Email}"      Width="170"/>
                            <DataGridTextColumn Header="Роль ID"  Binding="{Binding RoleId}"    Width="75"/>
                            <DataGridTemplateColumn Header="Роль" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Padding="4,2" HorizontalAlignment="Center"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Покупатель"/>
                                                    <Setter Property="Foreground" Value="#555"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RoleId}" Value="1">
                                                            <Setter Property="Text" Value="Администратор"/>
                                                            <Setter Property="Foreground" Value="DarkRed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding RoleId}" Value="2">
                                                            <Setter Property="Text" Value="Менеджер"/>
                                                            <Setter Property="Foreground" Value="DarkOrange"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding RoleId}" Value="3">
                                                            <Setter Property="Text" Value="Покупатель"/>
                                                            <Setter Property="Foreground" Value="#1565C0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Панель назначения роли -->
                    <Border Grid.Row="1" Background="White" CornerRadius="8"
                            Margin="0,8,0,0" Padding="14,10"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Выбранный пользователь:"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock x:Name="SelectedUserBlock" Grid.Column="1"
                                       FontWeight="Bold" VerticalAlignment="Center"
                                       Foreground="#1A237E"/>

                            <TextBlock Text="Назначить роль:" Grid.Column="2"
                                       VerticalAlignment="Center" Margin="20,0,10,0"/>
                            <ComboBox x:Name="RoleComboBox" Grid.Column="3"
                                      Width="160" Height="32" Margin="0,0,10,0">
                                <ComboBoxItem Content="1 — Администратор" Tag="1"/>
                                <ComboBoxItem Content="2 — Менеджер"      Tag="2"/>
                                <ComboBoxItem Content="3 — Покупатель"    Tag="3"/>
                            </ComboBox>
                            <Button Grid.Column="4" Content="Сохранить"
                                    Width="110" Height="32"
                                    Background="#388E3C" Foreground="White"
                                    Click="OnSaveRoleClick"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Все заказы -->
            <TabItem Header="📋 Все заказы">
                <DataGrid x:Name="AllOrdersGrid" Margin="8"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserResizeColumns="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"      Binding="{Binding Id}"         Width="55"/>
                        <DataGridTextColumn Header="Логин"   Binding="{Binding UserLogin}"   Width="110"/>
                        <DataGridTextColumn Header="Товар"   Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Кол-во"  Binding="{Binding Quantity}"    Width="75"/>
                        <DataGridTextColumn Header="Цена, ₽"
                                            Binding="{Binding UnitPrice, StringFormat=\{0:N0\}}" Width="100"/>
                        <DataGridTextColumn Header="Дата"
                                            Binding="{Binding OrderDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="105"/>
                        <DataGridTextColumn Header="Статус"  Binding="{Binding Status}"      Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Поставщики -->
            <TabItem Header="📦 Поставщики">
                <DataGrid x:Name="SuppliersGrid" Margin="8"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserResizeColumns="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"         Binding="{Binding Id}"          Width="55"/>
                        <DataGridTextColumn Header="Поставщик"  Binding="{Binding Name}"         Width="*"/>
                        <DataGridTextColumn Header="Контакт"    Binding="{Binding ContactName}"  Width="140"/>
                        <DataGridTextColumn Header="Телефон"    Binding="{Binding ContactPhone}" Width="140"/>
                        <DataGridTextColumn Header="Email"      Binding="{Binding Email}"         Width="170"/>
                        <DataGridTextColumn Header="Адрес"      Binding="{Binding Address}"       Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

        </TabControl>
    </Grid>
</Page>
