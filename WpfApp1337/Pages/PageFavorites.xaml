<Page x:Class="WpfApp1337.Pages.PageFavorites"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Width="500" Height="500"
      Title="Избранное" Background="#F4F6F8">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="46"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <TextBlock Text="⭐ Избранное" VerticalAlignment="Center"
                           FontSize="18" FontWeight="Bold" Foreground="#1A237E"/>
                <Button Content="← Назад" Width="90" Height="32"
                        HorizontalAlignment="Right" Click="OnBackClick"/>
            </Grid>
        </Border>
        <ListView x:Name="FavList" Grid.Row="1" Margin="16,10,16,4"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,3"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" CornerRadius="8" Padding="12"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="78" Height="66" CornerRadius="6"
                                    ClipToBounds="True" Background="#F5F5F5">
                                <Image Source="{Binding ImagePath}" Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock FontSize="12" Foreground="Gray" Margin="0,2">
                                    <Run Text="{Binding Brand}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding Category}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding Description}" FontSize="11"
                                           Foreground="#999" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="17" FontWeight="Bold" Foreground="#1565C0">
                                <Run Text="{Binding Price, StringFormat={}{0:N0}}"/>
                                <Run Text=" ₽"/>
                            </TextBlock>
                            <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="8,0,0,0">
                                <Button Content="🛒 В корзину" Height="28" Margin="0,0,0,6"
                                        Tag="{Binding}" Click="OnAddToCartClick"/>
                                <Button Content="✕ Удалить" Height="28"
                                        Tag="{Binding}" Click="OnDeleteClick"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <TextBlock x:Name="CountBlock" VerticalAlignment="Center"
                       Margin="20,0" FontSize="13" Foreground="#555"/>
        </Border>
    </Grid>
</Page>