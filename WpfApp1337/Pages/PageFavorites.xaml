<Page x:Class="WpfApp1337.Pages.PageFavorites"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F7F8FA">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="White">
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28" Background="#E63946"
                            CornerRadius="4" Margin="0,0,10,0">
                        <TextBlock Text="T" FontFamily="Segoe UI Black"
                                   FontSize="16" Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Избранное"
                               FontFamily="Segoe UI Semibold" FontSize="18"
                               Foreground="#1A1A2E" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Content="← Назад" Style="{StaticResource BtnOutline}"
                        HorizontalAlignment="Right" Click="OnBackClick"/>
            </Grid>
        </Border>
        <Rectangle Grid.Row="1" Fill="#E5E7EB"/>

        <!-- Список -->
        <ScrollViewer Grid.Row="2" Margin="20,16,20,0"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="FavList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="8"
                                Margin="0,0,0,10" Padding="16"
                                BorderBrush="#E5E7EB" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="82"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="68" Height="60" CornerRadius="6"
                                        ClipToBounds="True" Background="#F3F4F6">
                                    <Image Source="{Binding ImagePath}"
                                           Stretch="UniformToFill"/>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="16,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontFamily="Segoe UI Semibold"
                                               FontSize="14" Foreground="#1A1A2E"/>
                                    <TextBlock FontFamily="Segoe UI"
                                               FontSize="12" Foreground="#6B7280"
                                               Margin="0,4,0,0">
                                        <Run Text="{Binding Brand}"/>
                                        <Run Text=" · "/>
                                        <Run Text="{Binding Category}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Description}"
                                               FontFamily="Segoe UI" FontSize="11"
                                               Foreground="#9CA3AF"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,3,0,0"/>
                                </StackPanel>

                                <!-- Цена -->
                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center">
                                    <TextBlock FontFamily="Segoe UI Black"
                                               FontSize="20" Foreground="#E63946"
                                               HorizontalAlignment="Center">
                                        <Run Text="{Binding Price, StringFormat={}{0:N0}}"/>
                                    </TextBlock>
                                    <TextBlock Text="₽" FontFamily="Segoe UI"
                                               FontSize="13" Foreground="#E63946"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- Кнопки -->
                                <StackPanel Grid.Column="3"
                                            VerticalAlignment="Center"
                                            Margin="12,0,0,0">
                                    <Button Content="В корзину"
                                            Style="{StaticResource BtnPrimary}"
                                            Margin="0,0,0,8"
                                            Tag="{Binding}"
                                            Click="OnAddToCartClick"/>
                                    <Button Content="Удалить"
                                            Style="{StaticResource BtnDanger}"
                                            Tag="{Binding}"
                                            Click="OnDeleteClick"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Счётчик -->
        <Border Grid.Row="3" Background="White"
                BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <TextBlock x:Name="CountBlock" VerticalAlignment="Center"
                       Margin="20,0" FontFamily="Segoe UI"
                       FontSize="13" Foreground="#6B7280"/>
        </Border>
    </Grid>
</Page>
