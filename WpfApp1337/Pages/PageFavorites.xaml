<Page x:Class="WpfApp1337.Pages.PageFavorites"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Избранное — Магазин бытовой техники"
      Width="1100" Height="640">

    <Grid Background="#F4F6F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="White" BorderBrush="Gold" BorderThickness="0,0,0,2">
            <DockPanel Margin="20,0">
                <TextBlock Text="⭐ Избранные товары"
                           FontSize="20" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <Button Content="← Назад"
                        Width="100" Height="35"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right"
                        Click="OnBackClick"/>
            </DockPanel>
        </Border>

        <!-- Список избранного -->
        <ListView x:Name="FavoritesListView"
                  Grid.Row="1"
                  Margin="20,10"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" CornerRadius="8"
                            Margin="0,4" Padding="12"
                            BorderBrush="#DDD" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <!-- Фото товара (ИСПРАВЛЕНО - убран проблемный триггер) -->
                            <Border Grid.Column="0" Width="90" Height="80"
                                    CornerRadius="6" ClipToBounds="True"
                                    Background="#F0F0F0">
                                <Image Source="{Binding ImagePath, FallbackValue=/Resources/no_image.png, TargetNullValue=/Resources/no_image.png}"
                                       Stretch="UniformToFill"/>
                            </Border>

                            <!-- Инфо о товаре -->
                            <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Brand}"
                                           Foreground="Gray" FontSize="12" Margin="0,2"/>
                                <TextBlock Text="{Binding Category}"
                                           Foreground="#666" FontSize="11"/>
                                <TextBlock Text="{Binding Description}"
                                           Foreground="#888" FontSize="11"
                                           TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                            </StackPanel>

                            <!-- Цена -->
                            <TextBlock Grid.Column="2"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="#2196F3">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:N0} ₽">
                                        <Binding Path="Price"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <!-- Кнопки -->
                            <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                <Button Content="В корзину"
                                        Width="110" Height="30" Margin="0,0,0,6"
                                        Background="#2196F3" Foreground="White"
                                        Click="OnAddToCartClick"
                                        DataContext="{Binding}"/>
                                <Button Content="✕ Удалить"
                                        Width="110" Height="30"
                                        Background="#F44336" Foreground="White"
                                        Click="OnDeleteFavoriteClick"
                                        DataContext="{Binding}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Нижняя панель -->
        <Border Grid.Row="2" Background="White" BorderBrush="#DDD" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,20,0">
                <TextBlock x:Name="CountTextBlock"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"
                           FontSize="13" Foreground="#555"/>
                <Button Content="📄 Сформировать PDF"
                        Width="160" Height="36" Margin="0,0,10,0"
                        Click="OnGeneratePdfClick"/>
                <Button Content="📱 QR-код каталога"
                        Width="150" Height="36"
                        Click="OnShowQRClick"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>