<Page x:Class="WpfApp1337.Pages.AddRecip"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F7F8FA">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="White">
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28" Background="#E63946"
                            CornerRadius="4" Margin="0,0,10,0">
                        <TextBlock Text="T" FontFamily="Segoe UI Black"
                                   FontSize="16" Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Редактирование товара"
                               FontFamily="Segoe UI Semibold" FontSize="18"
                               Foreground="#1A1A2E" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Content="← Отмена" Style="{StaticResource BtnOutline}"
                        HorizontalAlignment="Right" Click="OnCancelClick"/>
            </Grid>
        </Border>
        <Rectangle Grid.Row="1" Fill="#E5E7EB"/>

        <!-- Форма -->
        <Grid Grid.Row="2" VerticalAlignment="Center"
              HorizontalAlignment="Center" Width="500">
            <Border Background="White" CornerRadius="8"
                    BorderBrush="#E5E7EB" BorderThickness="1"
                    Padding="36,32">
                <StackPanel>
                    <TextBlock Text="Название" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="NameTextBox"
                             Style="{StaticResource InputField}"
                             Margin="0,0,0,18"/>

                    <TextBlock Text="Категория" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="CategoryComboBox"
                              Style="{StaticResource ComboField}"
                              Margin="0,0,0,18"/>

                    <TextBlock Text="Бренд" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="BrandTextBox"
                             Style="{StaticResource InputField}"
                             Margin="0,0,0,18"/>

                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Цена, ₽" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="PriceTextBox" Style="{StaticResource InputField}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Количество" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="QuantityTextBox" Style="{StaticResource InputField}"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Сохранить"
                                Style="{StaticResource BtnPrimary}"
                                Height="44" FontSize="14"
                                Click="OnSaveClick"/>
                        <Button Grid.Column="2" Content="Отмена"
                                Style="{StaticResource BtnOutline}"
                                Height="44" FontSize="14"
                                Click="OnCancelClick"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
