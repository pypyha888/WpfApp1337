<Page x:Class="WpfApp1337.Pages.PageCatalog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Каталог" Background="#F4F6F8" Height="458" Width="1110">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <TextBlock x:Name="HeaderTextBlock" VerticalAlignment="Center"
                           FontSize="15" FontWeight="Bold" Foreground="#1A237E"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="⭐ Избранное" Width="110" Height="32" Margin="0,0,6,0"
                            Click="OnFavoritesClick"/>
                    <Button Content="🛒 Корзина"   Width="100" Height="32" Margin="0,0,6,0"
                            Click="OnCartClick"/>
                    <Button Content="👤 Кабинет"  Width="100" Height="32" Margin="0,0,6,0"
                            Click="OnProfileClick"/>
                    <Button x:Name="AdminButton"
                            Content="⚙ Админ"     Width="90"  Height="32" Margin="0,0,6,0"
                            Click="OnAdminClick"/>
                    <Button Content="Выйти"        Width="80"  Height="32"
                            Click="OnLogoutClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Фильтры -->
        <Border Grid.Row="1" Background="White" Margin="16,8,16,4"
                CornerRadius="8" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="SearchBox" Grid.Column="1" Height="30"
                         VerticalContentAlignment="Center"
                         TextChanged="OnFilterChanged"/>
                <TextBlock Text="Категория:" Grid.Column="2" VerticalAlignment="Center"
                           Margin="12,0,8,0"/>
                <ComboBox x:Name="CategoryBox" Grid.Column="3" Height="30"
                          SelectionChanged="OnFilterChanged"/>
                <TextBlock Text="Сортировка:" Grid.Column="4" VerticalAlignment="Center"
                           Margin="12,0,8,0"/>
                <ComboBox x:Name="SortBox" Grid.Column="5" Height="30"
                          SelectionChanged="OnSortChanged"/>
            </Grid>
        </Border>

        <!-- Таблица товаров -->
        <DataGrid x:Name="ProductsGrid" Grid.Row="2"
                  Margin="16,4,16,4"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  RowHeight="68" CanUserResizeColumns="True"
                  SelectionMode="Single"
                  MouseDoubleClick="OnProductDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="48"/>
                <DataGridTemplateColumn Header="Фото" Width="78">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Width="64" Height="58" CornerRadius="4"
                                    ClipToBounds="True" Background="#F0F0F0">
                                <Image Source="{Binding ImagePath}" Stretch="UniformToFill"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Название"  Binding="{Binding Name}"     Width="*"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Category}"  Width="155"/>
                <DataGridTextColumn Header="Бренд"     Binding="{Binding Brand}"     Width="100"/>
                <DataGridTextColumn Header="Цена, ₽"
                                    Binding="{Binding Price, StringFormat=\{0:N0\}}" Width="100"/>
                <DataGridTextColumn Header="Кол-во"    Binding="{Binding Quantity}"  Width="72"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Нижняя панель -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <TextBlock x:Name="CounterBlock" VerticalAlignment="Center"
                           FontSize="12" Foreground="#555"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="🛒 В корзину"   Width="110" Height="28" Margin="0,0,6,0"
                            Click="OnAddToCartClick"/>
                    <Button Content="⭐ В избранное" Width="120" Height="28" Margin="0,0,6,0"
                            Click="OnAddToFavClick"/>
                    <Button x:Name="BtnAdd"    Content="➕ Добавить" Width="100" Height="28"
                            Margin="0,0,6,0"   Click="OnAddProductClick"/>
                    <Button x:Name="BtnEdit"   Content="✏ Изменить" Width="100" Height="28"
                            Margin="0,0,6,0"   Click="OnEditProductClick"/>
                    <Button x:Name="BtnDelete" Content="🗑 Удалить"  Width="100" Height="28"
                            Click="OnDeleteProductClick"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
