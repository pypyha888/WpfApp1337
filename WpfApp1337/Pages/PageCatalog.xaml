<Page x:Class="WpfApp1337.Pages.PageCatalog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:WpfApp1337.Pages"
      Background="#F7F8FA">

    <Page.Resources>
        <local:ImagePathConverter x:Key="ImgConv"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>   <!-- Шапка -->
            <RowDefinition Height="1"/>    <!-- Разделитель -->
            <RowDefinition Height="60"/>   <!-- Фильтры -->
            <RowDefinition Height="*"/>    <!-- Таблица -->
            <RowDefinition Height="52"/>   <!-- Нижняя панель -->
        </Grid.RowDefinitions>

        <!-- ══ ШАПКА ════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White">
            <Grid Margin="20,0">
                <!-- Логотип + название -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28" Background="#E63946"
                            CornerRadius="4" Margin="0,0,10,0">
                        <TextBlock Text="T" FontFamily="Segoe UI Black"
                                   FontSize="16" Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="HeaderTextBlock"
                               FontFamily="Segoe UI" FontSize="14"
                               Foreground="#1A1A2E" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Навигация -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="⭐  Избранное"
                            Style="{StaticResource BtnNav}"
                            Margin="0,0,4,0" Click="OnFavoritesClick"/>
                    <Button Content="🛒  Корзина"
                            Style="{StaticResource BtnNav}"
                            Margin="0,0,4,0" Click="OnCartClick"/>
                    <Button Content="👤  Кабинет"
                            Style="{StaticResource BtnNav}"
                            Margin="0,0,4,0" Click="OnProfileClick"/>
                    <Button x:Name="AdminButton"
                            Content="⚙  Админ"
                            Style="{StaticResource BtnPrimary}"
                            Margin="0,0,8,0" Click="OnAdminClick"/>
                    <Button Content="Выйти"
                            Style="{StaticResource BtnOutline}"
                            Click="OnLogoutClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Разделитель -->
        <Rectangle Grid.Row="1" Fill="#E5E7EB"/>

        <!-- ══ ПАНЕЛЬ ФИЛЬТРОВ ══════════════════════════════ -->
        <Border Grid.Row="2" Background="White" Margin="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Поиск:" Grid.Column="0"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI" FontSize="13"
                           Foreground="#6B7280" Margin="0,0,10,0"/>
                <TextBox x:Name="SearchBox" Grid.Column="1"
                         Style="{StaticResource InputField}"
                         TextChanged="OnFilterChanged"/>

                <TextBlock Text="Категория:" Grid.Column="2"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI" FontSize="13"
                           Foreground="#6B7280" Margin="16,0,10,0"/>
                <ComboBox x:Name="CategoryBox" Grid.Column="3"
                          Style="{StaticResource ComboField}"
                          SelectionChanged="OnFilterChanged"/>

                <TextBlock Text="Сортировка:" Grid.Column="4"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI" FontSize="13"
                           Foreground="#6B7280" Margin="16,0,10,0"/>
                <ComboBox x:Name="SortBox" Grid.Column="5"
                          Style="{StaticResource ComboField}"
                          SelectionChanged="OnSortChanged"/>
            </Grid>
        </Border>

        <!-- ══ ТАБЛИЦА ТОВАРОВ ══════════════════════════════ -->
        <DataGrid x:Name="ProductsGrid" Grid.Row="3"
                  Margin="20,12,20,0"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserResizeColumns="True" RowHeight="68"
                  SelectionMode="Single"
                  MouseDoubleClick="OnProductDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}" Width="55"/>

                <DataGridTemplateColumn Header="Фото" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Width="72" Height="58" CornerRadius="4"
                                    ClipToBounds="True" Background="#F3F4F6"
                                    Margin="8,0">
                                <Image Stretch="UniformToFill">
                                    <Image.Source>
                                        <Binding Path="ImagePath"
                                                 Converter="{StaticResource ImgConv}"/>
                                    </Image.Source>
                                </Image>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Название"
                                    Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Категория"
                                    Binding="{Binding Category}" Width="160"/>
                <DataGridTextColumn Header="Бренд"
                                    Binding="{Binding Brand}" Width="110"/>
                <DataGridTextColumn Header="Цена, ₽"
                                    Binding="{Binding Price, StringFormat=\{0:N0\}}"
                                    Width="110"/>
                <DataGridTextColumn Header="Кол-во"
                                    Binding="{Binding Quantity}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ══ НИЖНЯЯ ПАНЕЛЬ ════════════════════════════════ -->
        <Border Grid.Row="4" Background="White"
                BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <TextBlock x:Name="CounterBlock"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI" FontSize="13"
                           Foreground="#6B7280"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="В корзину"
                            Style="{StaticResource BtnOutline}"
                            Margin="0,0,6,0" Click="OnAddToCartClick"/>
                    <Button Content="⭐ В избранное"
                            Style="{StaticResource BtnOutline}"
                            Margin="0,0,6,0" Click="OnAddToFavClick"/>
                    <Button x:Name="BtnAdd"
                            Content="Добавить"
                            Style="{StaticResource BtnPrimary}"
                            Margin="0,0,6,0" Click="OnAddProductClick"/>
                    <Button x:Name="BtnEdit"
                            Content="Изменить"
                            Style="{StaticResource BtnOutline}"
                            Margin="0,0,6,0" Click="OnEditProductClick"/>
                    <Button x:Name="BtnDelete"
                            Content="Удалить"
                            Style="{StaticResource BtnDanger}"
                            Click="OnDeleteProductClick"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
