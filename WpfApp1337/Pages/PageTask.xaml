<Page x:Class="WpfApp1337.Pages.PageTask"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель управления — Магазин бытовой техники"
      Width="1200" Height="640">

    <Grid Background="#F4F6F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="Gold" BorderThickness="0,0,0,1">
            <DockPanel Margin="20,0,20,0">
                <TextBlock x:Name="UserHeaderTextBlock" 
                           FontSize="18" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <Button x:Name="LogoutButton"
                        Content="Выйти" 
                        Width="100" 
                        HorizontalAlignment="Right" 
                        DockPanel.Dock="Right" 
                        Click="OnLogoutClick"
                        Height="35"
                        Margin="10,0,0,0"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Margin="20,10,20,10"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Поиск:" VerticalAlignment="Center" Grid.Column="0"/>
                <TextBox x:Name="SearchTextBox" 
                         Grid.Column="1" 
                         Margin="4,0" 
                         TextChanged="OnFilterChanged"
                         Height="35"
                         VerticalContentAlignment="Center"/>

                <TextBlock Text="Фильтр:" VerticalAlignment="Center" Grid.Column="2" Margin="12,0,0,0"/>
                <ComboBox x:Name="CategoryFilterComboBox" 
                          Grid.Column="3" 
                          Margin="4,0" 
                          SelectionChanged="OnFilterChanged"
                          Height="35"/>

                <TextBlock Text="Сорт:" VerticalAlignment="Center" Grid.Column="4" Margin="12,0,0,0"/>
                <ComboBox x:Name="SortComboBox" 
                          Grid.Column="5" 
                          Margin="4,0" 
                          SelectionChanged="OnSortChanged"
                          Height="35"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="2" 
                    x:Name="TablesTabControl"
                    Margin="20,0,20,10">

            <TabItem Header="Общая таблица (Товары)">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="ProductsDataGrid" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              CanUserResizeColumns="True"
                              MouseDoubleClick="ProductsDataGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="170"/>
                            <DataGridTextColumn Header="Бренд" Binding="{Binding Brand}" Width="120"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="120"/>
                            <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right" 
                                Margin="0,8,0,0">
                        <Button x:Name="AddToCartButton" 
                                Content="В корзину" 
                                Width="110" 
                                Margin="0,0,8,0" 
                                Click="OnAddToCartClick"
                                Height="32"/>
                        <Button x:Name="AddProductButton" 
                                Content="Добавить" 
                                Width="110" 
                                Margin="0,0,8,0" 
                                Click="OnAddProductClick"
                                Height="32"/>
                        <Button x:Name="EditProductButton" 
                                Content="Изменить" 
                                Width="110" 
                                Margin="0,0,8,0" 
                                Click="OnEditProductClick"
                                Height="32"/>
                        <Button x:Name="DeleteProductButton" 
                                Content="Удалить" 
                                Width="110" 
                                Click="OnDeleteProductClick"
                                Height="32"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Личный кабинет и корзина">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Background="#E8F0FE" 
                            CornerRadius="8" 
                            Padding="10" 
                            Margin="0,0,0,10">
                        <TextBlock x:Name="ProfileTextBlock" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"/>
                    </Border>

                    <DataGrid x:Name="CartDataGrid" 
                              Grid.Row="1" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              CanUserResizeColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID товара" Binding="{Binding ProductId}" Width="90"/>
                            <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice}" Width="120"/>
                            <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="100"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding TotalPrice}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right" 
                                Margin="0,8,0,0">
                        <TextBlock x:Name="CartTotalTextBlock" 
                                   VerticalAlignment="Center" 
                                   FontWeight="Bold" 
                                   FontSize="14"
                                   Margin="0,0,16,0"/>
                        <Button x:Name="RemoveFromCartButton"
                                Content="Удалить из корзины" 
                                Width="150" 
                                Margin="0,0,8,0" 
                                Click="OnRemoveFromCartClick"
                                Height="32"/>
                        <Button x:Name="CheckoutButton"
                                Content="Оформить заказ" 
                                Width="130" 
                                Click="OnCheckoutClick"
                                Height="32"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem x:Name="SuppliersTab" Header="Поставщики">
                <DataGrid x:Name="SuppliersDataGrid"
                          IsReadOnly="True" 
                          AutoGenerateColumns="False" 
                          Margin="6">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                        <DataGridTextColumn Header="Поставщик" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Телефон" Binding="{Binding ContactPhone}" Width="180"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem x:Name="OrdersTab" Header="Заказы">
                <DataGrid x:Name="OrdersDataGrid" 
                          IsReadOnly="True" 
                          AutoGenerateColumns="False" 
                          Margin="6">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                        <DataGridTextColumn Header="Логин" Binding="{Binding UserLogin}" Width="130"/>
                        <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="120"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding OrderDate}" Width="150"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3"
                Background="#E8F0FE"
                CornerRadius="0,0,10,10"
                Margin="20,0,20,10">
            <Grid>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            Margin="20,0,0,0">
                    <TextBlock x:Name="tbCounter" 
                               Text="Найдено товаров: 0" 
                               FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Margin="0,0,20,0">
                    <Button x:Name="RefreshButton"
                            Content="Обновить"
                            Width="100"
                            Height="30"
                            Click="OnRefreshClick"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>