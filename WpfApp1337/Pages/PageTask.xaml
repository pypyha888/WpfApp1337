<Page x:Class="WpfApp1337.Pages.PageTask"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель управления — Магазин бытовой техники"
      Width="1200" Height="640">

    <Grid Background="#F4F6F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" BorderBrush="Gold" BorderThickness="0,0,0,1" Background="White">
            <DockPanel Margin="20,0,20,0">
                <TextBlock x:Name="UserHeaderTextBlock"
                           FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right">
                    <!-- Кнопка Избранное -->
                    <Button x:Name="FavoritesButton"
                            Content="⭐ Избранное"
                            Width="120" Height="35"
                            Margin="0,0,10,0"
                            Click="OnOpenFavoritesClick"/>
                    <Button x:Name="LogoutButton"
                            Content="Выйти"
                            Width="90" Height="35"
                            Click="OnLogoutClick"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Панель фильтров -->
        <Border Grid.Row="1" Background="White" CornerRadius="10"
                Margin="20,10,20,10" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Поиск:" VerticalAlignment="Center" Grid.Column="0"/>
                <TextBox x:Name="SearchTextBox" Grid.Column="1" Margin="4,0"
                         TextChanged="OnFilterChanged" Height="35" VerticalContentAlignment="Center"/>
                <TextBlock Text="Фильтр:" VerticalAlignment="Center" Grid.Column="2" Margin="12,0,0,0"/>
                <ComboBox x:Name="CategoryFilterComboBox" Grid.Column="3" Margin="4,0"
                          SelectionChanged="OnFilterChanged" Height="35"/>
                <TextBlock Text="Сорт:" VerticalAlignment="Center" Grid.Column="4" Margin="12,0,0,0"/>
                <ComboBox x:Name="SortComboBox" Grid.Column="5" Margin="4,0"
                          SelectionChanged="OnSortChanged" Height="35"/>
            </Grid>
        </Border>

        <!-- Вкладки -->
        <TabControl Grid.Row="2" x:Name="TablesTabControl" Margin="20,0,20,10">

            <!-- Вкладка: Товары -->
            <TabItem Header="Общая таблица (Товары)">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="ProductsDataGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserResizeColumns="True"
                              RowHeight="70"
                              MouseDoubleClick="ProductsDataGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>

                            <!-- Фото товара -->
                            <DataGridTemplateColumn Header="Фото" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="65" Height="60" CornerRadius="4"
                                                ClipToBounds="True" Background="#F5F5F5">
                                            <Image Stretch="UniformToFill">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Source" Value="/Resources/no_image.png"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ImagePath}" Value="{x:Null}">
                                                                <Setter Property="Source" Value="/Resources/no_image.png"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                                <Image.Source>
                                                    <Binding Path="ImagePath"/>
                                                </Image.Source>
                                            </Image>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Название"  Binding="{Binding Name}"     Width="*"/>
                            <DataGridTextColumn Header="Категория" Binding="{Binding Category}"  Width="160"/>
                            <DataGridTextColumn Header="Бренд"     Binding="{Binding Brand}"     Width="110"/>
                            <DataGridTextColumn Header="Цена, ₽"   Binding="{Binding Price, StringFormat=\{0:N0\}}" Width="100"/>
                            <DataGridTextColumn Header="Кол-во"    Binding="{Binding Quantity}"  Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Кнопки под таблицей -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button x:Name="AddToCartButton"
                                Content="🛒 В корзину" Width="110" Height="32" Margin="0,0,6,0"
                                Click="OnAddToCartClick"/>
                        <!-- Кнопка избранного -->
                        <Button x:Name="AddToFavoritesButton"
                                Content="⭐ Избранное" Width="110" Height="32" Margin="0,0,6,0"
                                Click="OnAddToFavoritesClick"/>
                        <Button x:Name="AddProductButton"
                                Content="Добавить" Width="100" Height="32" Margin="0,0,6,0"
                                Click="OnAddProductClick"/>
                        <Button x:Name="EditProductButton"
                                Content="Изменить" Width="100" Height="32" Margin="0,0,6,0"
                                Click="OnEditProductClick"/>
                        <Button x:Name="DeleteProductButton"
                                Content="Удалить" Width="100" Height="32"
                                Click="OnDeleteProductClick"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Вкладка: Личный кабинет и корзина -->
            <TabItem Header="Личный кабинет и корзина">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Background="#E8F0FE" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                        <TextBlock x:Name="ProfileTextBlock" FontSize="14" FontWeight="SemiBold"/>
                    </Border>
                    <DataGrid x:Name="CartDataGrid" Grid.Row="1"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserResizeColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID товара"  Binding="{Binding ProductId}"  Width="90"/>
                            <DataGridTextColumn Header="Товар"      Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Цена, ₽"    Binding="{Binding UnitPrice, StringFormat=\{0:N0\}}" Width="110"/>
                            <DataGridTextColumn Header="Кол-во"     Binding="{Binding Quantity}"    Width="80"/>
                            <DataGridTextColumn Header="Сумма, ₽"   Binding="{Binding TotalPrice, StringFormat=\{0:N0\}}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,8,0,0">
                        <TextBlock x:Name="CartTotalTextBlock"
                                   VerticalAlignment="Center" FontWeight="Bold" FontSize="14"
                                   Margin="0,0,16,0"/>
                        <Button Content="Удалить из корзины" Width="150" Height="32" Margin="0,0,8,0"
                                Click="OnRemoveFromCartClick"/>
                        <Button Content="Оформить заказ" Width="130" Height="32"
                                Click="OnCheckoutClick"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Вкладка: Поставщики (Admin/Manager) -->
            <TabItem x:Name="SuppliersTab" Header="Поставщики">
                <DataGrid x:Name="SuppliersDataGrid" IsReadOnly="True"
                          AutoGenerateColumns="False" Margin="6">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"         Binding="{Binding Id}"           Width="60"/>
                        <DataGridTextColumn Header="Поставщик"  Binding="{Binding Name}"          Width="*"/>
                        <DataGridTextColumn Header="Контакт"    Binding="{Binding ContactName}"   Width="150"/>
                        <DataGridTextColumn Header="Телефон"    Binding="{Binding ContactPhone}"  Width="150"/>
                        <DataGridTextColumn Header="Email"      Binding="{Binding Email}"          Width="180"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Вкладка: Заказы -->
            <TabItem x:Name="OrdersTab" Header="Заказы">
                <DataGrid x:Name="OrdersDataGrid" IsReadOnly="True"
                          AutoGenerateColumns="False" Margin="6">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"         Binding="{Binding Id}"         Width="60"/>
                        <DataGridTextColumn Header="Логин"      Binding="{Binding UserLogin}"   Width="120"/>
                        <DataGridTextColumn Header="Товар"      Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Кол-во"     Binding="{Binding Quantity}"    Width="80"/>
                        <DataGridTextColumn Header="Цена, ₽"    Binding="{Binding UnitPrice, StringFormat=\{0:N0\}}" Width="100"/>
                        <DataGridTextColumn Header="Дата"       Binding="{Binding OrderDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="110"/>
                        <DataGridTextColumn Header="Статус"     Binding="{Binding Status}"      Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <!-- Нижняя строка -->
        <Border Grid.Row="3" Background="#E8F0FE" CornerRadius="0,0,10,10" Margin="20,0,20,10">
            <Grid>
                <TextBlock x:Name="tbCounter" Text="Найдено товаров: 0"
                           FontSize="12" VerticalAlignment="Center"
                           HorizontalAlignment="Left" Margin="20,0,0,0"/>
                <Button x:Name="RefreshButton" Content="Обновить"
                        Width="100" Height="30" HorizontalAlignment="Right"
                        Margin="0,0,20,0" Click="OnRefreshClick"/>
            </Grid>
        </Border>
    </Grid>
</Page>
