<Page x:Class="WpfApp1337.Pages.Autorization"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F7F8FA">

    <Grid>
        <!-- Левая декоративная полоса -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.42*"/>
            <ColumnDefinition Width="0.58*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель — брендинг -->
        <Border Grid.Column="0" Background="#E63946">
            <StackPanel VerticalAlignment="Center" Margin="60,0">
                <TextBlock Text="TECHNO" FontFamily="Segoe UI Black"
                           FontSize="48" Foreground="White" LineHeight="50"/>
                <TextBlock Text="SHOP" FontFamily="Segoe UI Black"
                           FontSize="48" Foreground="White" Opacity="0.35"
                           Margin="0,-8,0,0" LineHeight="50"/>
                <Rectangle Height="3" Width="60" Fill="White"
                           HorizontalAlignment="Left" Margin="0,24,0,20"/>
                <TextBlock Text="Магазин бытовой техники"
                           FontFamily="Segoe UI" FontSize="15"
                           Foreground="White" Opacity="0.85"/>
                <TextBlock Text="Лучшие бренды. Лучшие цены."
                           FontFamily="Segoe UI" FontSize="13"
                           Foreground="White" Opacity="0.6" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- Правая панель — форма входа -->
        <Border Grid.Column="1" Background="White">
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center"
                  Width="380">
                <StackPanel>
                    <!-- Заголовок -->
                    <TextBlock Text="Вход в аккаунт"
                               FontFamily="Segoe UI Semibold" FontSize="26"
                               Foreground="#1A1A2E" Margin="0,0,0,6"/>
                    <TextBlock Text="Введите ваши данные для входа"
                               FontFamily="Segoe UI" FontSize="13"
                               Foreground="#6B7280" Margin="0,0,0,36"/>

                    <!-- Логин -->
                    <TextBlock Text="Логин" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="txtLogin"
                             Style="{StaticResource InputField}"
                             Margin="0,0,0,20"/>

                    <!-- Пароль -->
                    <TextBlock Text="Пароль" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="txtPassword"
                                 Style="{StaticResource PassField}"
                                 Margin="0,0,0,32"/>

                    <!-- Кнопка входа -->
                    <Button Content="ВОЙТИ"
                            Style="{StaticResource BtnPrimary}"
                            Height="44" FontSize="14"
                            Click="btnVhod_Click"
                            Margin="0,0,0,20"/>

                    <!-- Ссылка на регистрацию -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <TextBlock Text="Нет аккаунта?"
                                   FontFamily="Segoe UI"
                                   FontSize="13" Foreground="#6B7280"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <Button x:Name="btnReg"
                                Content="Зарегистрироваться"
                                Style="{StaticResource BtnNav}"
                                Foreground="#E63946"
                                FontWeight="SemiBold"
                                Click="btnReg_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
