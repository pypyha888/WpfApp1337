<Page x:Class="WpfApp1337.Pages.Autorization"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вход" Height="350" Width="594">
    <Grid Background="#FF50" Margin="0,-87,-30,-57">
        <Label Content="Логин" Margin="196,111,196,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txtLogin" Margin="196,142,196,0" VerticalAlignment="Top"/>

        <Label Content="Пароль" Margin="196,180,196,0" VerticalAlignment="Top"/>
        <PasswordBox x:Name="txtPassword" Margin="196,210,196,0" VerticalAlignment="Top"/>

        <Button x:Name="btnVhod" Content="Войти" Margin="212,260,212,0" VerticalAlignment="Top"
            Click="btnVhod_Click"/>
        <Label Content="Нет аккаунта? Зарегистрироваться" Margin="196,300,196,0" VerticalAlignment="Top"/>
        <Button x:Name="btnReg" Content="Зарегистрироваться" Margin="212,330,212,0" VerticalAlignment="Top"
            Click="btnReg_Click"/>
    </Grid>
</Page>
