<Page x:Class="WpfApp1337.Pages.PageProfile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Личный кабинет" Background="#F4F6F8" Height="479" Width="840">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <TextBlock Text="👤 Личный кабинет" VerticalAlignment="Center"
                           FontSize="18" FontWeight="Bold" Foreground="#1A237E"/>
                <Button Content="← Назад" Width="90" Height="32"
                        HorizontalAlignment="Right" Click="OnBackClick"/>
            </Grid>
        </Border>

        <!-- Карточка пользователя -->
        <Border Grid.Row="1" Background="White" CornerRadius="10"
                Margin="16,12,16,8" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Аватар -->
                <Border Width="64" Height="64" CornerRadius="32"
                        Background="#1A237E">
                    <TextBlock x:Name="AvatarBlock" FontSize="28" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Данные -->
                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="NameBlock"  FontSize="16" FontWeight="Bold"/>
                    <TextBlock x:Name="LoginBlock" FontSize="12" Foreground="Gray" Margin="0,3"/>
                    <TextBlock x:Name="RoleBlock"  FontSize="12" Foreground="#1565C0"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Контакты -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock x:Name="PhoneBlock" FontSize="12" Foreground="Gray"/>
                    <TextBlock x:Name="EmailBlock" FontSize="12" Foreground="Gray" Margin="0,3"/>
                    <TextBlock x:Name="SinceBlock" FontSize="11" Foreground="#AAA"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- История заказов -->
        <Grid Grid.Row="2" Margin="16,0,16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="История заказов" FontSize="14" FontWeight="Bold"
                       Margin="0,0,0,8"/>
            <DataGrid x:Name="OrdersGrid" Grid.Row="1"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserResizeColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№"        Binding="{Binding Id}"         Width="55"/>
                    <DataGridTextColumn Header="Товар"    Binding="{Binding ProductName}" Width="*"/>
                    <DataGridTextColumn Header="Кол-во"   Binding="{Binding Quantity}"    Width="75"/>
                    <DataGridTextColumn Header="Сумма, ₽"
                                        Binding="{Binding UnitPrice, StringFormat=\{0:N0\}}" Width="110"/>
                    <DataGridTextColumn Header="Дата"
                                        Binding="{Binding OrderDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="105"/>
                    <DataGridTemplateColumn Header="Статус" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Status}" Padding="4,2"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Выполнен">
                                                    <Setter Property="Foreground" Value="Green"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Оформлен">
                                                    <Setter Property="Foreground" Value="#1565C0"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Отменён">
                                                    <Setter Property="Foreground" Value="Red"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Page>
