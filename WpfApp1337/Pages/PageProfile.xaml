<Page x:Class="WpfApp1337.Pages.PageProfile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F7F8FA">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="White">
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28" Background="#E63946"
                            CornerRadius="4" Margin="0,0,10,0">
                        <TextBlock Text="T" FontFamily="Segoe UI Black"
                                   FontSize="16" Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Личный кабинет"
                               FontFamily="Segoe UI Semibold" FontSize="18"
                               Foreground="#1A1A2E" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Content="← Назад" Style="{StaticResource BtnOutline}"
                        HorizontalAlignment="Right" Click="OnBackClick"/>
            </Grid>
        </Border>
        <Rectangle Grid.Row="1" Fill="#E5E7EB"/>

        <!-- Карточка пользователя -->
        <Border Grid.Row="2" Background="White"
                Margin="20,16,20,12" CornerRadius="8"
                BorderBrush="#E5E7EB" BorderThickness="1"
                Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Аватар -->
                <Border Width="56" Height="56" CornerRadius="28"
                        Background="#E63946">
                    <TextBlock x:Name="AvatarBlock"
                               FontFamily="Segoe UI Black" FontSize="22"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Имя и роль -->
                <StackPanel Grid.Column="1" Margin="16,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="NameBlock"
                               FontFamily="Segoe UI Semibold" FontSize="16"
                               Foreground="#1A1A2E"/>
                    <TextBlock x:Name="LoginBlock"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="#6B7280" Margin="0,4"/>
                    <Border CornerRadius="4" Padding="8,3"
                            HorizontalAlignment="Left">
                        <Border.Background>
                            <SolidColorBrush Color="#FFF0F0"/>
                        </Border.Background>
                        <TextBlock x:Name="RoleBlock"
                                   FontFamily="Segoe UI" FontSize="12"
                                   FontWeight="SemiBold" Foreground="#E63946"/>
                    </Border>
                </StackPanel>

                <!-- Контакты -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock x:Name="PhoneBlock"
                               FontFamily="Segoe UI" FontSize="13"
                               Foreground="#374151"/>
                    <TextBlock x:Name="EmailBlock"
                               FontFamily="Segoe UI" FontSize="13"
                               Foreground="#374151" Margin="0,5"/>
                </StackPanel>

                <!-- Дата регистрации -->
                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                    <TextBlock x:Name="SinceBlock"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="#9CA3AF"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Заголовок секции -->
        <TextBlock Grid.Row="3" Text="ИСТОРИЯ ЗАКАЗОВ"
                   FontFamily="Segoe UI" FontSize="11"
                   FontWeight="SemiBold" Foreground="#6B7280"
                   Margin="20,0,0,10"/>

        <!-- Таблица заказов -->
        <DataGrid x:Name="OrdersGrid" Grid.Row="4"
                  Margin="20,0,20,20"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserResizeColumns="True" RowHeight="44">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№"
                                    Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="Товар"
                                    Binding="{Binding ProductName}" Width="*"/>
                <DataGridTextColumn Header="Кол-во"
                                    Binding="{Binding Quantity}" Width="80"/>
                <DataGridTextColumn Header="Сумма, ₽"
                                    Binding="{Binding UnitPrice, StringFormat=\{0:N0\}}"
                                    Width="120"/>
                <DataGridTextColumn Header="Дата"
                                    Binding="{Binding OrderDate, StringFormat=\{0:dd.MM.yyyy\}}"
                                    Width="110"/>
                <DataGridTemplateColumn Header="Статус" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="8,3"
                                    HorizontalAlignment="Left" Margin="8,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#F3F4F6"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Выполнен">
                                                <Setter Property="Background" Value="#DCFCE7"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Оформлен">
                                                <Setter Property="Background" Value="#EFF6FF"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Отменён">
                                                <Setter Property="Background" Value="#FFF0F0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Status}"
                                           FontFamily="Segoe UI" FontSize="12"
                                           FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#374151"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Выполнен">
                                                    <Setter Property="Foreground" Value="#16A34A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Оформлен">
                                                    <Setter Property="Foreground" Value="#2563EB"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Отменён">
                                                    <Setter Property="Foreground" Value="#E63946"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
