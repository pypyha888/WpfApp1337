<Page x:Class="WpfApp1337.Pages.Reg"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F7F8FA">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.42*"/>
            <ColumnDefinition Width="0.58*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель -->
        <Border Grid.Column="0" Background="#E63946">
            <StackPanel VerticalAlignment="Center" Margin="60,0">
                <TextBlock Text="TECHNO" FontFamily="Segoe UI Black"
                           FontSize="48" Foreground="White" LineHeight="50"/>
                <TextBlock Text="SHOP" FontFamily="Segoe UI Black"
                           FontSize="48" Foreground="White" Opacity="0.35"
                           Margin="0,-8,0,0" LineHeight="50"/>
                <Rectangle Height="3" Width="60" Fill="White"
                           HorizontalAlignment="Left" Margin="0,24,0,20"/>
                <TextBlock Text="Создайте аккаунт и получите доступ к каталогу техники"
                           FontFamily="Segoe UI" FontSize="14"
                           Foreground="White" Opacity="0.85"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Правая панель — форма -->
        <Border Grid.Column="1" Background="White">
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center"
                  Width="420">
                <StackPanel>
                    <TextBlock Text="Регистрация"
                               FontFamily="Segoe UI Semibold" FontSize="26"
                               Foreground="#1A1A2E" Margin="0,0,0,6"/>
                    <TextBlock Text="Заполните данные для создания аккаунта"
                               FontFamily="Segoe UI" FontSize="13"
                               Foreground="#6B7280" Margin="0,0,0,32"/>

                    <TextBlock Text="Имя" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="FullNameTextBox"
                             Style="{StaticResource InputField}"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="Логин" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="LoginTextBox"
                             Style="{StaticResource InputField}"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="Пароль" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource PassField}"
                                 PasswordChanged="PasswordBoxes_PasswordChanged"
                                 Margin="0,0,0,16"/>

                    <TextBlock Text="Повторите пароль" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 Style="{StaticResource PassField}"
                                 PasswordChanged="PasswordBoxes_PasswordChanged"
                                 Margin="0,0,0,28"/>

                    <Button x:Name="RegisterButton"
                            Content="ЗАРЕГИСТРИРОВАТЬСЯ"
                            Style="{StaticResource BtnPrimary}"
                            Height="44" FontSize="14"
                            Click="OnRegisterClick"
                            Margin="0,0,0,12"/>

                    <Button x:Name="BackButton"
                            Content="← Вернуться к входу"
                            Style="{StaticResource BtnOutline}"
                            Click="BackButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
